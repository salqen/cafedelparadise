# Skopíruj tento súbor ako .env a vyplň hodnoty zo Supabase (Project Settings → API).
# .env NEcommituj do gitu (je v .gitignore).

# --- Klientské (prehliadač) — musia mať prefix VITE_ ---
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...   # "anon public" key

# --- Serverové (len pre Vercel funkcie, NIKDY do klienta) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...  # "service_role" key — TAJNÝ!

# Pre AI funkcie:
ANTHROPIC_API_KEY=sk-ant-...
